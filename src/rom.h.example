/*
 * rom.h - Tamagotchi P1 ROM data
 *
 * This file is NOT included in the repository. You must provide the ROM
 * yourself. The P1 ROM was extracted from die photography and is widely
 * available in the Tamagotchi emulation community — search for "tamagotchi
 * p1 rom bin" and look at the MCUGotchi or ArduinoGotchi project pages for
 * pointers to where the community sources it.
 *
 * The ROM binary must be repacked into 12-bit words (u12_t) because the
 * E0C6S46 CPU has 12-bit wide program memory. Use the provided
 * convert_rom.py script:
 *
 *   python3 convert_rom.py rom.bin > src/rom.h
 *
 * The result should look like:
 *
 *   static const u12_t tamagotchi_rom[] = {
 *     0x000, 0x001, ...
 *   };
 */
 
#pragma once
 
// extern "C" guard so the C array is accessible from the C++ translation unit
#ifdef __cplusplus
extern "C" {
#endif
 
#include "../lib/tamalib/hal_types.h"
 
/* ROM data goes here — generated by convert_rom.py, e.g.:
static const u12_t tamagotchi_rom[] = {
    0x000, 0x001, ...
};
*/
 
#ifdef __cplusplus
}
#endif